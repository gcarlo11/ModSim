totalKeHelpdesk++;
totalWaktuLayanan += ped.waktuLayanan;

traceln("SELESAI_LAYANAN " + ped.idPed + " | durasi=" + String.format("%.1f", ped.waktuLayanan) + " mnt");]]></Code>
